@startuml c4_container
!theme plain
!include <C4/C4_Container>
title Notifications - Containers

Person(participant, "Participant / Facilitator", "Authenticated user viewing the bell in the app header")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(browser, "Web Browser", "React 19 client components", "NotificationCenter renders the bell, badge, dropdown and toasts; subscribes to a per-user Realtime channel")
  Container(server, "Next.js Server", "App Router - server components, route handlers, proxy middleware", "Zoom create-meeting route handler inserts meeting_scheduled notifications server-side")
  ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced", "notifications table; supabase_realtime publication broadcasts INSERTs per subscriber")
}

Rel(participant, browser, "Sees badge count and toast alerts")
Rel(browser, supabase, "Initial unread fetch + INSERT / UPDATE (mark read) via browser client")
Rel(browser, supabase, "Subscribes to channel notifications:<userId>, filter user_id=eq.<userId>")
Rel(supabase, browser, "Realtime INSERT events for the user's own rows (SELECT RLS gate)")
Rel(server, supabase, "Inserts meeting_scheduled row for the meeting partner")

@enduml

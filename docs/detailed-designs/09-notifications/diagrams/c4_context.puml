@startuml c4_context
!theme plain
!include <C4/C4_Context>
title Notifications - System Context

Person(participant, "Participant", "Receives alerts about connect requests, messages, meetings and match approvals")
Person(facilitator, "Facilitator", "Receives alerts and approves matches that notify participants")

System(rtr, "Reconciliation Through Relationships", "Web platform connecting Indigenous and non-Indigenous participants for relationship building")

System_Ext(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced. Stores and broadcasts notification rows")

Rel(participant, rtr, "Views bell badge, opens dropdown, gets toasts")
Rel(facilitator, rtr, "Views bell badge, opens dropdown, gets toasts")
Rel(rtr, supabase, "Inserts notifications for recipients; subscribes to own INSERTs over Realtime")
Rel_Back(participant, supabase, "Realtime INSERT events scoped to their user_id")

@enduml

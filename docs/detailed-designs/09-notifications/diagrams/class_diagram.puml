@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
title Notifications - Data Model

entity notifications {
  + id : uuid <<PK>>
  --
  user_id : uuid <<FK profiles.id>>
  type : text <<connect_request | match_approved | new_message | meeting_scheduled>>
  title : text  <<not null>>
  body : text  <<nullable>>
  data : jsonb  <<default '{}'>>
  read : boolean  <<not null, default false>>
  created_at : timestamptz  <<default now()>>
}

entity profiles {
  + id : uuid <<PK, = auth.users.id>>
  --
  first_name : text
  last_name : text
  role : text
}

profiles ||--o{ notifications : "recipient (user_id)\non delete cascade"

note bottom of notifications
  data payload by type (verified at producer call sites):
  connect_request     -> { connection_id }
  new_message         -> { connection_id }
  meeting_scheduled   -> { connection_id, meeting_id }
  match_approved      -> { match_id } or { connection_id }
end note

@enduml

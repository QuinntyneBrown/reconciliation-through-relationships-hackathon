@startuml sequence_realtime_delivery
!theme plain
skinparam sequenceMessageAlign center
title Realtime notification delivery

actor "Producer\n(other user's action)" as producer
database "Supabase\nnotifications + Realtime" as db
participant "NotificationCenter\n(recipient browser)" as center
actor "Recipient" as user

producer -> db : notifications.insert({ user_id: recipient, type, title, body, data })
note right of db : INSERT RLS: auth.uid() is not null\nrow persists addressed to recipient
db -> center : Realtime INSERT event on channel notifications:<userId>\n(filter user_id=eq.<userId>, gated by SELECT RLS)
center -> center : dedupe by id, prepend, slice(0,20); unread badge +1
center -> user : sonner toast(title, body) with "View" action

alt clicks toast "View"
  user -> center : onClick
  center -> user : router.push(targetHref(n))  (does not mark read)
else opens bell, clicks a dropdown row
  user -> center : handleClick(n)
  center -> db : update({ read: true }).eq("id", n.id)
  center -> user : router.push(targetHref(n))
end

@enduml

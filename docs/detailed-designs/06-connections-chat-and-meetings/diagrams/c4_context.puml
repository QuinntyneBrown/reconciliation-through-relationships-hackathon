@startuml c4_context
!theme plain
!include <C4/C4_Context>
title Connections: Chat & Meetings - System Context

Person(participantA, "Participant A", "One side of a mutual connection")
Person(participantB, "Participant B", "The other side of the connection")

System(rtr, "Reconciliation Through Relationships", "Web platform connecting Indigenous and non-Indigenous participants for relationship building")

System_Ext(supabase, "Supabase", "Postgres + Auth + Realtime; RLS-enforced messages, meetings and connection status")
System_Ext(zoom, "Zoom API", "Server-to-Server OAuth meeting creation")

Rel(participantA, rtr, "Accepts connection, chats, schedules calls")
Rel(participantB, rtr, "Accepts connection, chats, joins calls")
Rel(rtr, supabase, "Reads/writes messages, meetings, connection status; subscribes to Realtime")
Rel(rtr, zoom, "Creates meetings (server-side)", "HTTPS / OAuth")
@enduml

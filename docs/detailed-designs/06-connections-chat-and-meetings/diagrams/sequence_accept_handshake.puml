@startuml sequence_accept_handshake
!theme plain
skinparam sequenceMessageAlign center
title Mutual-Connect Handshake (accept)

actor "Participant B" as B
participant "ConnectionChat (B)" as CB
database "Supabase\n(RLS)" as SB
participant "ConnectionChat (A)" as CA

B -> CB : Click "Connect with A" (handleConnect)
opt partner already connected
  CB -> SB : select system_settings.value\nwhere key = 'auto_matching_enabled'
  SB --> CB : value
end
CB -> SB : connections.update(participant_b_connected = true, ...)
alt both connected AND auto_matching
  note right of SB : status = 'active', connected_at = now()
else both connected AND NOT auto_matching
  note right of SB : status = 'pending_review'
end
CB -> SB : notifications.insert(type='connect_request' -> A)
SB --> CA : Realtime UPDATE (connections)
CA -> CA : setConnectionState; toast if status='active'
@enduml

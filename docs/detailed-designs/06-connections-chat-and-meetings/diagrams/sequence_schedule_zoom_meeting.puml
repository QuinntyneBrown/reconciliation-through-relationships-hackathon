@startuml sequence_schedule_zoom_meeting
!theme plain
skinparam sequenceMessageAlign center
title Schedule a Zoom Meeting

actor "Participant" as U
participant "ScheduleMeetingModal" as M
participant "Zoom Route\n/api/zoom/create-meeting" as R
database "Supabase\n(RLS)" as SB
participant "Zoom API" as Z

U -> M : Schedule call (date, time, topic)
M -> R : POST /api/zoom/create-meeting
R -> SB : auth.getUser()  (401 if unauthenticated)
R -> SB : select connection; verify caller is participant (403 if not)
R -> Z : POST oauth/token (account_credentials grant)
R -> Z : POST /users/me/meetings
Z --> R : id, join_url, start_url
R -> SB : meetings.insert({zoom_*, scheduled_at, created_by})
R -> SB : notifications.insert(type='meeting_scheduled' -> partner)
R --> M : meeting JSON -> render join card
@enduml

@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
title Connections: Chat & Meetings - Data Model

class connections {
  id : uuid <<PK>>
  participant_a_id : uuid <<FK profiles>>
  participant_b_id : uuid <<FK profiles>>
  participant_a_connected : boolean = false
  participant_b_connected : boolean = false
  connected_at : timestamptz
  status : text  {pending | pending_review | active}
}

class messages {
  id : uuid <<PK>>
  connection_id : uuid <<FK connections>>
  sender_id : uuid <<FK profiles>>
  content : text
  read_at : timestamptz
  created_at : timestamptz
}

class meetings {
  id : uuid <<PK>>
  connection_id : uuid <<FK connections>>
  zoom_meeting_id : text
  zoom_join_url : text
  scheduled_at : timestamptz
  duration_minutes : int = 60
  created_by : uuid <<FK profiles>>
}

class notifications {
  id : uuid <<PK>>
  user_id : uuid <<FK profiles>>
  type : text  {connect_request | new_message | meeting_scheduled}
  data : jsonb  {connection_id, meeting_id}
}

class system_settings {
  key : text <<PK>>  = 'auto_matching_enabled'
  value : jsonb
}

connections "1" --> "0..*" messages : contains
connections "1" --> "0..*" meetings : schedules
connections ..> system_settings : reads on handshake
connections ..> notifications : triggers on accept
messages ..> notifications : triggers on send
meetings ..> notifications : triggers on schedule
@enduml

@startuml c4_container
!theme plain
!include <C4/C4_Container>
title Connections: Chat & Meetings - Containers

Person(participant, "Participant", "A connection participant")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(browser, "Web Browser", "React 19 client components", "ConnectionChat & ScheduleMeetingModal: send messages, accept the handshake, subscribe to Realtime")
  Container(server, "Next.js Server", "App Router - server components, route handlers, proxy middleware", "Connections list & thread pages; POST /api/zoom/create-meeting handler")
  ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced", "connections, messages, meetings, system_settings, notifications")
}

System_Ext(zoom, "Zoom API", "Server-to-Server OAuth meeting creation")

Rel(participant, browser, "Chats, accepts, schedules calls", "HTTPS")
Rel(browser, supabase, "Insert messages, update connection, subscribe to Realtime", "supabase-js")
Rel(browser, server, "POST /api/zoom/create-meeting; page navigations", "HTTPS / fetch")
Rel(server, supabase, "Read connection/profiles/messages/meetings; insert meeting & notification", "@supabase/ssr")
Rel(server, zoom, "Mint S2S token, create meeting", "HTTPS / OAuth")
@enduml

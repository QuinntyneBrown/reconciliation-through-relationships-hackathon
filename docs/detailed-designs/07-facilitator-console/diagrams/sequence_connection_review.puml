@startuml sequence_connection_review
!theme plain
skinparam sequenceMessageAlign center
title Mutual-Connect Review - pending_review connection (auto-matching OFF)

actor "Facilitator" as F
participant "matching/page.tsx\n(server)" as PG
participant "MatchingClient" as MC
database "Supabase\n(RLS)" as SB

note over PG : Row originates from the peer handshake\n(both participants clicked Connect) - see doc 06
PG -> SB : connections.select where status='pending_review'
SB --> PG : rows -> reviewList
F -> MC : Approve / Reject a mutual-connect request
alt approve
  MC -> SB : connections.update({status:'active',\nconnected_at}) where id
  SB --> MC : ok
  MC -> SB : notifications.insert([match_approved x2])
  MC --> F : toast "Connection approved"; drop from list
else reject
  MC -> SB : connections.delete() where id
  MC --> F : toast "Connection rejected"; drop from list
end
@enduml

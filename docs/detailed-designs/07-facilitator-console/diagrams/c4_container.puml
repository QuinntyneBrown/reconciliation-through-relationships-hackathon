@startuml c4_container
!theme plain
!include <C4/C4_Container>
title Facilitator Console - Containers

Person(facilitator, "Facilitator", "Oversees the RTR community")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(web, "Web Browser", "React 19 client components", "MatchingClient, ParticipantsTable, SettingsClient, FacilitatorNav")
  Container(next, "Next.js Server", "App Router - server components, route handlers, proxy middleware", "Facilitator server pages + role gate")
  ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced")
}

Rel(facilitator, web, "Uses")
Rel(web, next, "Requests /facilitator pages", "HTTPS")
Rel(next, supabase, "Server reads: 5 counts, participants, matches, settings", "supabase-js (SSR cookies)")
Rel(web, supabase, "Client writes: match / connection / settings / notification mutations", "supabase-js (RLS)")
@enduml

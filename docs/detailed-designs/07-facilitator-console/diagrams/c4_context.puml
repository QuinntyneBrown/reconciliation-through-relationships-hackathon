@startuml c4_context
!theme plain
!include <C4/C4_Context>
title Facilitator Console - System Context

Person(facilitator, "Facilitator", "Staff member who oversees participants, matches and platform settings")

System(rtr, "Reconciliation Through Relationships", "Web platform connecting Indigenous and non-Indigenous participants for relationship building")

System_Ext(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced")

Rel(facilitator, rtr, "Reviews participants, approves matches & mutual connections, edits settings")
Rel(rtr, supabase, "Reads counts / participants / matches; writes match, connection, settings & notification rows", "HTTPS / RLS")
@enduml

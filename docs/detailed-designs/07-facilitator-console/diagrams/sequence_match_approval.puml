@startuml sequence_match_approval
!theme plain
skinparam sequenceMessageAlign center
title Match Approval / Rejection - MatchingClient.updateMatchStatus

actor "Facilitator" as F
participant "MatchingClient" as MC
database "Supabase\n(RLS)" as SB

F -> MC : Approve / Reject a suggested match
alt status = approved
  MC -> SB : matches.update({status:'approved',\napproved_by, approved_at}) where id
  SB --> MC : ok  (RLS: facilitators manage all matches)
  MC -> SB : connections.insert({match_id,\nparticipant_a_id=indigenous, participant_b_id=non_indigenous})
  loop each participant (2x)
    MC -> SB : notifications.insert({type:'match_approved', user_id, ...})
  end
  MC --> F : toast "Match approved and participants notified"
else status = rejected
  MC -> SB : matches.update({status:'rejected'}) where id
  MC --> F : toast "Match rejected"
end
@enduml

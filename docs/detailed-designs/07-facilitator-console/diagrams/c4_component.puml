@startuml c4_component
!theme plain
!include <C4/C4_Component>
title Facilitator Console - Components

Person(facilitator, "Facilitator", "")

Container_Boundary(app, "Facilitator Console (Next.js + React)") {
  Component(overview, "Facilitator overview page", "Server Component", "src/app/facilitator/page.tsx - 5 parallel count queries + quick actions")
  Component(participants, "ParticipantsTable", "Client Component", "In-memory search / filter / paginate; derives journey status from props")
  Component(matching, "MatchingClient", "Client Component", "Match approve/reject, manual match, mutual-connect review queue, auto-matching toggle")
  Component(settings, "SettingsClient", "Client Component", "Edits auto_matching_enabled & cohort_threshold")
  Component(pm, "profile-matching", "TypeScript module", "computeMatches / criteriaLabels scoring")
}

ContainerDb(supabase, "Supabase", "Postgres + RLS")

Rel(facilitator, overview, "Views stats & quick actions")
Rel(facilitator, participants, "Searches & filters")
Rel(facilitator, matching, "Approves / creates matches")
Rel(facilitator, settings, "Saves settings")

Rel(overview, supabase, "SSR reads 5 counts (profiles, matches, connections, cohorts)")
Rel(participants, supabase, "Rows pre-loaded by its server page (SSR); table filters in memory")
Rel(matching, pm, "Computes score + criteria for a manual match")
Rel(matching, supabase, "matches / connections / system_settings / notifications writes")
Rel(settings, supabase, "system_settings upsert")
@enduml

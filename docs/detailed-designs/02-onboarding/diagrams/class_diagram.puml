@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
title Onboarding - profiles columns written by the wizard

class profiles {
  id : uuid <<PK, FK auth.users>>
  .. Basic info (StepBasicInfo) ..
  first_name : text
  last_name : text
  bio : text
  additional_matching_info : text
  is_indigenous : boolean
  sex : text <<male|female|prefer_not_to_say>>
  age : integer <<13..120>>
  participation_categories : text[]
  .. Location (StepLocation) ..
  city : text
  province : text
  treaty_area : text
  .. Faith & interests (StepFaithInterests) ..
  faith_tradition : text
  faith_tradition_other : text
  interests : text[]
  .. Availability (StepAvailability) ..
  availability : jsonb <<{days,times}>>
  participation_format : text[]
  language_preferences : text[]
  .. Matching prefs (StepMatchingPreferences) ..
  personal_boundaries : text
  matching_preferences : jsonb <<{weight_sex,weight_interests,weight_location}>>
  map_consent : boolean
  .. Completion flag ..
  onboarding_completed : boolean
  updated_at : timestamptz
}

note right of profiles
  One row per user, created on signup by the
  handle_new_user() trigger. The wizard performs a
  single UPDATE on the caller's own row.
  lat / lng exist on this table but are populated
  by the map feature, not by onboarding.
end note
@enduml

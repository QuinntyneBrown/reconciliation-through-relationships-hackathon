@startuml sequence_complete_onboarding
!theme plain
skinparam sequenceMessageAlign center
title Complete onboarding

actor Participant
participant "OnboardingPage\n(wizard)" as Page
participant "Step + Validation" as Step
database "Supabase" as DB

loop per step 1..5
  Participant -> Step : fill fields, click Continue
  Step -> Step : validate(data)
  alt has errors
    Step --> Participant : focus error summary, mark aria-invalid
  else valid
    Step -> Page : onNext() -> advance step
  end
end

Participant -> Page : click "Complete profile" (step 5)
Page -> DB : auth.getUser()
alt no session
  Page --> Participant : redirect /auth/login
else
  Page -> DB : UPDATE profiles SET ..., onboarding_completed=true WHERE id = user.id
  alt update fails
    DB --> Page : error -> toast, stay on step 5
  else success
    DB --> Page : ok -> toast, router.push('/learn')
  end
end
@enduml

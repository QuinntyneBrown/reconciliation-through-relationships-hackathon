@startuml c4_component
!theme plain
!include <C4/C4_Component>
title Onboarding - Components (Web Browser)

Person(participant, "Participant", "")

Container_Boundary(browser, "Web Browser - /onboarding") {
  Component(page, "OnboardingPage", "React client page (page.tsx)", "Holds wizard state (step, data, saving); renders one step at a time; writes profiles on final submit")
  Component(basic, "StepBasicInfo", "React client component", "Name, age, bio, Indigenous, sex, participation categories")
  Component(location, "StepLocation", "React client component", "City, province/territory, treaty area")
  Component(faith, "StepFaithInterests", "React client component", "Faith tradition + free-form interest tags")
  Component(availability, "StepAvailability", "React client component", "Days/times, participation format, languages")
  Component(matching, "StepMatchingPreferences", "React client component", "Match weightings, boundaries, map consent; triggers submit")
  Component(validation, "Validation module", "validation.ts + useStepValidation + OnboardingErrors", "Pure per-step validators, submit gate, accessible error summary + field messages")
}

ContainerDb(supabase, "Supabase", "Postgres + Auth", "profiles row, RLS-enforced")

Rel(participant, page, "Uses the wizard")
Rel(page, basic, "Renders (step 0)")
Rel(page, location, "Renders (step 1)")
Rel(page, faith, "Renders (step 2)")
Rel(page, availability, "Renders (step 3)")
Rel(page, matching, "Renders (step 4)")
Rel(basic, validation, "Validates on Continue")
Rel(location, validation, "Validates on Continue")
Rel(faith, validation, "Validates on Continue")
Rel(availability, validation, "Validates on Continue")
Rel(page, supabase, "UPDATE profiles (onboarding_completed = true)")
@enduml

@startuml sequence_region_listing
!theme plain
skinparam sequenceMessageAlign center

title Region Listing - GET /map (server render)

actor Participant
participant "map/page.tsx" as Page
database Supabase
participant "getRepository()" as Factory
participant "MockRepository" as Repo

Participant -> Page : GET /map
Page -> Supabase : auth.getUser()
alt no session
  Page --> Participant : redirect /auth/login
end
Page -> Supabase : from("profiles").select(role).single()
opt no profile row
  Page --> Participant : redirect /onboarding
end
Page -> Factory : getRepository()
note right of Factory : DATA_SOURCE=mock (default)\n=> MockRepository singleton
Page -> Repo : listRegions() + listMappableParticipants()
Repo -> Repo : filter isEligible(p) && p.consentToMap,\ngroup by city, tag canFormCohort (>= 5)
Repo --> Page : Region[] + ParticipantProfile[]
Page --> Participant : region cards (CohortCircle, seats remaining)

@enduml

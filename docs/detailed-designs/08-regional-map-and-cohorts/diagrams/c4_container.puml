@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Regional Map & Cohorts - Containers

Person(participant, "Participant", "Views regional cohorts")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(browser, "Web Browser", "React 19 client components", "Renders region cards / cohort circles")
  Container(server, "Next.js Server", "App Router — server components, route handlers", "/map page and /api/participants route")
  Container(seam, "Repository Seam", "getRepository() in src/data/index.ts", "Singleton factory; switches on DATA_SOURCE env var")
  Container(mockrepo, "MockRepository", "In-memory, synthetic data (default)", "Filters eligible+consented; aggregates regions")
  Container(stubrepo, "SupabaseRepository", "UNIMPLEMENTED STUB — every method throws", "DATA_SOURCE=supabase is non-functional for this feature")
}

ContainerDb(supabase, "Supabase", "Postgres + Auth, RLS-enforced", "Auth session + profile role only")

Rel(participant, browser, "Uses")
Rel(browser, server, "GET /map, GET/POST /api/participants", "HTTPS")
Rel(server, supabase, "auth.getUser(), profiles select role", "@supabase/ssr")
Rel(server, seam, "getRepository()")
Rel(seam, mockrepo, "DATA_SOURCE=mock (default)")
Rel(seam, stubrepo, "DATA_SOURCE=supabase — throws not-implemented", "dashed")

@enduml

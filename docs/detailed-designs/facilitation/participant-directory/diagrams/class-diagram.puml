@startuml
title Class view — Facilitator participant directory

skinparam backgroundColor #FFFDF7
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontColor #18352F
skinparam ArrowColor #2F6F67
skinparam packageBorderColor #477B73
skinparam packageBackgroundColor #EEF6F3
skinparam rectangleBorderColor #477B73
skinparam rectangleBackgroundColor #FFFFFF
skinparam componentBorderColor #8A5A1F
skinparam componentBackgroundColor #FFF6E6
skinparam databaseBorderColor #4E668E
skinparam databaseBackgroundColor #EEF3FB
skinparam actorBorderColor #18352F
skinparam actorBackgroundColor #FFFFFF
skinparam classBorderColor #477B73
skinparam classBackgroundColor #FFFFFF
skinparam sequenceBoxBorderColor #477B73
skinparam sequenceBoxBackgroundColor #F4F8F6
skinparam ParticipantBorderColor #477B73
skinparam ParticipantBackgroundColor #FFFFFF
skinparam BoxPadding 10
hide stereotype

left to right direction
package "Reconciliation Through Relationships application" {
  package "Facilitator participant directory structure" {
    class "ParticipantsTable" as type0 {
      -search
      -background: BackgroundFilter
      -journey: JourneyFilter
      -page
      +resetToFirstPage(setter)
    }
    
    class "BackgroundFilter" as type1 {
      all
      indigenous
      non_indigenous
    }
    
    class "JourneyFilter" as type2 {
      all
      ready
      learning
      onboarding
    }
    
    entity "Profile" as type3 {
      +identity
      +location
      +is_indigenous
      +onboarding_completed
      +learning_completed
      +created_at
    }
  }
}
type0 --> type1 : uses
type0 --> type2 : uses
type0 --> type3 : filters and renders
legend bottom
  Class = implementation component or value shape
  Interface = public TypeScript contract
  Entity = persisted or domain data record
endlegend
@enduml

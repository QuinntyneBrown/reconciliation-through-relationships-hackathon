@startuml c4_component
!theme plain
!include <C4/C4_Component>
title Learning Journey - Components

Person(participant, "Participant", "Completing required learning")

Container_Boundary(server, "Next.js Server") {
  Component(learnPage, "LearnPage", "Server component (src/app/learn/page.tsx)", "Resolves audience from profiles.is_indigenous; loads modules + progress")
  Component(proxy, "Proxy middleware", "src/data/supabase/session-proxy.ts", "Gates onboarded-but-unfinished participants to /learn until learning_completed")
}

Container_Boundary(browser, "Web Browser") {
  Component(layout, "LearningLayout", "Client component", "Module navigation, progress bar, markComplete upsert, gate-release update")
  Component(content, "ModuleContent", "Client component", "Renders YouTube iframe (video) or react-markdown (text) + Mark complete button")
}

ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced")
System_Ext(youtube, "YouTube", "Embedded video player")

Rel(participant, layout, "Views + marks complete")
Rel(proxy, supabase, "Reads profile gates", "postgrest")
Rel(learnPage, supabase, "Reads learning_modules + learning_progress", "postgrest")
Rel(learnPage, layout, "Renders with modules, progress, profile props")
Rel(layout, content, "Renders active module")
Rel(content, youtube, "Embeds content_url", "iframe")
Rel(layout, supabase, "Upserts learning_progress; updates learning_completed", "postgrest")
@enduml

@startuml sequence_route_gating
!theme plain
skinparam sequenceMessageAlign center
title Route Gating - updateSession decision cascade

actor "Browser" as B
participant "proxy.ts" as P
participant "updateSession\n(session-proxy.ts)" as US
database "Supabase\n(Auth + profiles)" as SB

B -> P : request /some-path (cookies)
P -> US : updateSession(request)

alt missing Supabase env OR path is public\n(/, /auth/*)
  US --> B : pass through (NextResponse.next)
else guarded path
  US -> SB : auth.getUser()
  SB --> US : user | null
  alt not authenticated
    US --> B : redirect /auth/login
  else authenticated
    US -> SB : select role, onboarding_completed,\nlearning_completed
    SB --> US : profile gates
    alt facilitator on /onboarding or /learn
      US --> B : redirect /facilitator
    else participant onboarding incomplete
      US --> B : redirect /onboarding
    else participant learning incomplete
      US --> B : redirect /learn
    else participant on /facilitator
      US --> B : redirect /dashboard
    else all gates satisfied
      US --> B : pass through
    end
  end
end
@enduml

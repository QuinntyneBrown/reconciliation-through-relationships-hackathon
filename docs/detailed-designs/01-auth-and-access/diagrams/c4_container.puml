@startuml c4_container
!theme plain
!include <C4/C4_Container>
title Authentication & Access - Containers

Person(visitor, "Visitor", "Unauthenticated")
Person(participant, "Participant", "Authenticated member")
Person(facilitator, "Facilitator", "Program staff")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(browser, "Web Browser", "React 19 client components", "Landing page, login & signup forms; calls Supabase Auth directly")
  Container(server, "Next.js Server", "App Router - server components, route handlers, proxy middleware", "Gates every request; handles the OAuth/magic-link callback")
  ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced", "Stores auth.users, profiles, and session cookies")
}

Rel(visitor, browser, "Opens /, /auth/login, /auth/signup", "HTTPS")
Rel(participant, browser, "Signs in", "HTTPS")
Rel(facilitator, browser, "Signs in", "HTTPS")

Rel(browser, supabase, "signUp / signInWithPassword", "supabase-js")
Rel(browser, server, "Navigations (cookies attached)", "HTTPS")
Rel(server, supabase, "getUser, exchangeCodeForSession, read profile gates", "@supabase/ssr")
@enduml

@startuml sequence_signup_and_callback
!theme plain
skinparam sequenceMessageAlign center
title Signup (password) and Callback (code exchange)

actor "Visitor" as V
participant "Signup Page\n(browser client)" as Signup
participant "Callback Route\n/auth/callback" as CB
database "Supabase Auth\n+ profiles (RLS)" as SB

group Password signup (src/app/auth/signup/page.tsx)
  V -> Signup : submit email + password
  Signup -> SB : signUp(email, password)
  note right of SB : on_auth_user_created trigger\ninserts profiles(id)
  Signup -> SB : signInWithPassword(email, password)
  SB --> Signup : session cookie
  Signup -> V : redirect /onboarding
end

group Code exchange (email link / magic link / OAuth)
  V -> CB : GET /auth/callback?code=...
  CB -> SB : exchangeCodeForSession(code)
  alt success
    CB -> SB : select role, onboarding_completed,\nlearning_completed
    CB -> V : redirect (facilitator | onboarding | learn | dashboard)
  else error
    CB -> V : redirect /auth/login?error=auth_failed
  end
end
@enduml

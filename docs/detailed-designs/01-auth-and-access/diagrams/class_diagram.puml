@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
title Authentication & Access - Gate-Relevant Data Model

class "auth.users" as users <<Supabase Auth>> {
  id : uuid <<PK>>
  email : text
  encrypted_password : text
}

class profiles {
  id : uuid <<PK, FK auth.users>>
  role : text  {participant | facilitator}
  onboarding_completed : boolean = false
  learning_completed : boolean = false
}

note bottom of profiles
  Only the gate-relevant columns are shown.
  RLS SELECT allows a user to read their own row
  (auth.uid() = id), so gate columns are always
  readable by the session that owns them.
end note

users "1" --> "1" profiles : trigger on_auth_user_created\n(handle_new_user, security definer)\ninserts profiles(id)
@enduml

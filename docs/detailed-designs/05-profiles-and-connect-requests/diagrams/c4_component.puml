@startuml c4_component
!theme plain
!include <C4/C4_Component>
title Profiles & Connect Requests - Components

Person(participant, "Participant", "Views profiles, sends/cancels connect requests")

Container_Boundary(app, "Reconciliation Through Relationships") {
  Component(me, "MyProfilePage", "Server Component - src/app/profile/me/page.tsx", "Resolves the signed-in user and redirects to /profile/{user.id}")
  Component(profile, "ProfilePage", "Server Component - src/app/profile/[userId]/page.tsx", "Loads viewer + subject profile and any existing connection; renders the profile display")
  Component(connect, "ConnectButton", "Client Component - src/app/profile/[userId]/ConnectButton.tsx", "State machine: connect / pending + cancel / respond / open chat")
}

ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced")

Rel(participant, me, "GET /profile/me")
Rel(participant, profile, "GET /profile/[userId]")
Rel(me, profile, "redirect(/profile/{user.id})")
Rel(profile, supabase, "select profiles; select connections (server client)")
Rel(profile, connect, "Renders with initialConnection prop")
Rel(connect, supabase, "insert/delete connections; insert notifications (browser client)")
@enduml

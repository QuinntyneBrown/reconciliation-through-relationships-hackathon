@startuml c4_container
!theme plain
!include <C4/C4_Container>
title Profiles & Connect Requests - Containers

Person(participant, "Participant", "Views profiles, sends/cancels connect requests")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(browser, "Web Browser", "React 19 client components", "Renders the profile page and runs the ConnectButton state machine")
  Container(next, "Next.js Server", "App Router - server components, route handlers, proxy middleware", "Renders /profile/me and /profile/[userId] server components")
}

ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced")

Rel(participant, browser, "Uses")
Rel(browser, next, "Requests /profile/[userId]", "HTTP")
Rel(next, supabase, "Reads viewer + subject profile and any existing connection (server client)", "supabase-js")
Rel(browser, supabase, "Inserts/deletes a connection; inserts a notification (browser client)", "supabase-js")
@enduml

@startuml c4_context
!theme plain
!include <C4/C4_Context>
title Participant Dashboard & Discovery - System Context

Person(participant, "Participant", "Indigenous or non-Indigenous member with onboarding + learning complete")

System(rtr, "Reconciliation Through Relationships", "Web platform connecting Indigenous and non-Indigenous participants for relationship building")

System_Ext(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced")
System_Ext(mapbox, "Mapbox GL", "Map tiles + rendering")

Rel(participant, rtr, "Opens /dashboard; browses recommendations, connections, and all participants")
Rel(rtr, supabase, "Reads profile, eligible participants, matches, connections, cohort membership", "HTTPS")
Rel(rtr, mapbox, "Loads tiles + renders participant markers (browser, if token set)", "HTTPS")
@enduml

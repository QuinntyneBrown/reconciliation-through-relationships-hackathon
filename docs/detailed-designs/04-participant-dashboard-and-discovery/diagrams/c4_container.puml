@startuml c4_container
!theme plain
!include <C4/C4_Container>
title Participant Dashboard & Discovery - Containers

Person(participant, "Participant", "Onboarding + learning complete")

System_Boundary(rtr, "Reconciliation Through Relationships") {
  Container(browser, "Web Browser", "React 19 client components", "DashboardClient, tabs, ParticipantMap, filters/pagination, sign-out")
  Container(server, "Next.js Server", "App Router — server components, route handlers, proxy middleware", "dashboard/page.tsx loads data + runs computeMatches")
  ContainerDb(supabase, "Supabase", "Postgres + Auth + Realtime, RLS-enforced", "profiles, matches, connections, cohort_members")
}

System_Ext(mapbox, "Mapbox GL", "Map tiles + rendering")

Rel(participant, browser, "Views dashboard, switches tabs, searches/filters")
Rel(browser, server, "Requests /dashboard (server component render)")
Rel(server, supabase, "auth.getUser + select profiles/matches/connections/cohort_members", "cookie session")
Rel(browser, mapbox, "Loads tiles + renders markers (Map view, if NEXT_PUBLIC_MAPBOX_TOKEN set)")
@enduml

@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
title Participant Dashboard & Discovery - Read Data Model

class profiles {
  id : uuid <<PK>>
  first_name : text
  last_name : text
  bio : text
  is_indigenous : boolean
  role : text  {participant | facilitator}
  onboarding_completed : boolean
  learning_completed : boolean
  city : text
  province : text
  interests : text[]
  availability : jsonb  {days, times}
  language_preferences : text[]
  faith_tradition : text
  participation_format : text[]
  participation_categories : text[]
  matching_preferences : jsonb
  map_consent : boolean
  lat : double precision
  lng : double precision
}

class matches {
  id : uuid <<PK>>
  indigenous_participant_id : uuid <<FK>>
  non_indigenous_participant_id : uuid <<FK>>
  status : text  {suggested|approved|rejected|connected}
}

class connections {
  id : uuid <<PK>>
  match_id : uuid <<FK, nullable>>
  participant_a_id : uuid <<FK>>
  participant_b_id : uuid <<FK>>
  participant_a_connected : boolean
  participant_b_connected : boolean
  status : text  {pending|pending_review|active}
}

class cohort_members {
  cohort_id : uuid <<FK>>
  participant_id : uuid <<FK>>
}

class MatchResult <<computeMatches output>> {
  participant : Profile
  score : number  {0..100}
  criteria.location : number  {0..30}
  criteria.availability : number  {0..20}
  criteria.interests : number  {0..20}
  criteria.language : number  {0..10}
  criteria.faith : number  {0..10}
  criteria.format : number  {0..10}
}

matches "0..*" --> "2" profiles : indigenous +\nnon_indigenous
connections "0..*" --> "2" profiles : participant_a +\nparticipant_b
cohort_members "0..*" --> "1" profiles : participant
MatchResult "1" --> "1" profiles : wraps candidate

note bottom of MatchResult
  Not a table. Computed in-memory by
  computeMatches() from a profile pair.
  score = sum of the six criteria.
end note
@enduml

@startuml c4_component
!theme plain
!include <C4/C4_Component>
title Participant Dashboard & Discovery - Components

Person(participant, "Participant")
System_Ext(supabase, "Supabase", "profiles, matches, connections, cohort_members (RLS)")

Container_Boundary(server, "Next.js Server") {
  Component(page, "DashboardPage loader", "server component, src/app/dashboard/page.tsx", "Auth + gate redirects; fetches profile, eligible participants, matches, connections, cohort; calls computeMatches")
  Component(matching, "profile-matching module", "src/domain/profile-matching.ts", "computeMatches + criteriaLabels: fixed-weight cross-background scoring (0-100)")
}

Container_Boundary(browser, "Web Browser (React client)") {
  Component(client, "DashboardClient", "client component", "Tabs shell, welcome intro, cohort banner + waitlist gating")
  Component(recommended, "RecommendedTab", "client component", "Top matches with score, criteria chips, connect/chat state")
  Component(connections, "ConnectionsTab", "client component", "Status filter + paginated connection list")
  Component(all, "AllParticipantsTab", "client component", "Search/province/faith/background filters, pagination, list/map toggle")
  Component(map, "ParticipantMap", "client component", "Mapbox markers for map_consent participants (no-op without token)")
  Component(cohort, "CohortBanner", "client component", "Cohort-forming prompt for elected leaders")
}

Rel(participant, page, "GET /dashboard")
Rel(page, supabase, "select profile / participants / matches / connections / cohort_members")
Rel(page, matching, "computeMatches(profile, participants)")
Rel(page, client, "renders with props")
Rel(client, recommended, "Recommended tab")
Rel(client, connections, "Connections tab")
Rel(client, all, "All participants tab")
Rel(client, cohort, "renders when threshold met")
Rel(all, map, "Map view toggle (passes filtered participants)")

note right of map
  Filters to map_consent && lat && lng,
  renders markers via Mapbox GL.
  Silent no-op when NEXT_PUBLIC_MAPBOX_TOKEN is unset.
end note
@enduml
